# Copy this file to `.env` and fill in ONE provider's key.
# `.env` is git-ignored — never commit a real key.
# Mutagen auto-loads `.env` from your working directory at startup.

# --- Pick the provider you configured in [llm] (default: anthropic) ---

ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# OPENROUTER_API_KEY=sk-or-...
